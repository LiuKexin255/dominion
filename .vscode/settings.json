{
    "go.goroot": "${workspaceFolder}/bazel-${workspaceFolderBasename}/external/rules_go++go_sdk+main___download_0",
    "go.toolsEnvVars": {
        "GOPACKAGESDRIVER": "${workspaceFolder}/tools/dev/go/gopackagesdriver.sh"
    },
    "yaml.schemas": {
        "tools/release/deploy/pkg/schema/service.schema.json": "service.yaml",
        "tools/release/deploy/pkg/schema/deploy.schema.json": "deploy.yaml"
    },
    "go.testFlags": [
        "-v"
    ],
    "postman.settings.dotenv-detection-notification-visibility": false,
    "gopls": {
        "build.workspaceFiles": [
            "**/BUILD",
            "**/WORKSPACE",
            "**/*.{bzl,bazel}"
        ],
        "build.directoryFilters": [
            "-bazel-bin",
            "-bazel-out",
            "-bazel-testlogs",
            "-bazel-yourrepo"
        ]
    }
}