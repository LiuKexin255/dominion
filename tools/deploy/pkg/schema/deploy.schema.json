{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deploy",
  "type": "object",
  "description": "部署环境定义",
  "additionalProperties": false,
  "required": [
    "name",
    "desc",
    "type",
    "services"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]{0,7}\\.[a-z][a-z0-9]{0,7}$",
      "description": "部署环境名称"
    },
    "desc": {
      "type": "string",
      "minLength": 1,
      "description": "环境描述"
    },
    "type": {
      "type": "string",
      "enum": ["prod", "test", "dev"],
      "description": "环境类型"
    },
    "uri": {
      "type": "string",
      "minLength": 1,
      "description": "部署配置资源标识"
    },
    "services": {
      "type": "array",
      "description": "部署的服务列表，同一个服务不能多次部署；TLS 运行时配置不允许出现在 deploy.yaml 中",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "artifact": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "name"
            ],
            "properties": {
              "path": {
                "type": "string",
                "description": "服务定义 yaml 路径"
              },
              "name": {
                "type": "string",
                "description": "产物别名"
              },
              "replicas": {
                "type": "integer",
                "minimum": 1,
                "description": "部署副本数，未设置时使用默认值"
              }
            }
          },
          "infra": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "resource",
              "profile",
              "name",
              "app"
            ],
            "properties": {
              "resource": {
                "type": "string",
                "enum": [
                  "mongodb"
                ]
              },
              "profile": {
                "type": "string",
                "minLength": 1,
                "description": "基础设施配置 profile"
              },
              "name": {
                "type": "string",
                "minLength": 1,
                "description": "基础设施实例名称"
              },
              "app": {
                "type": "string",
                "minLength": 1,
                "description": "基础设施所属应用名"
              },
              "persistence": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "enabled"
                ],
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  }
                }
              }
            }
          },
          "http": {
            "type": "object",
            "description": "http 路由设置",
            "additionalProperties": false,
            "required": [
              "hostnames",
              "matches"
            ],
            "properties": {
              "hostnames": {
                "type": "array",
                "description": "http 入口域名",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "matches": {
                "type": "array",
                "description": "路由匹配规则",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "minProperties": 1,
                  "required": [
                    "path",
                    "backend"
                  ],
                  "properties": {
                    "backend": {
                      "type": "string",
                      "minLength": 1,
                      "description": "后端 port 名称"
                    },
                    "path": {
                      "type": "object",
                      "additionalProperties": false,
                      "description": "路径匹配规则",
                      "required": [
                        "type",
                        "value"
                      ],
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": [
                            "PathPrefix"
                          ]
                        },
                        "value": {
                          "type": "string",
                          "minLength": 1
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "oneOf": [
          {
            "required": [
              "artifact"
            ],
            "not": {
              "required": [
                "infra"
              ]
            }
          },
          {
            "required": [
              "infra"
            ],
            "not": {
              "required": [
                "artifact"
              ]
            }
          }
        ]
      }
    }
  }
}
