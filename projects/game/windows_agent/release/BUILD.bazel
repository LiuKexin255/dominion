load("@rules_go//go:def.bzl", "go_binary", "go_library")
load("//tools/go:defs.bzl", "go_unittest")

go_library(
    name = "release_lib",
    srcs = [
        "checksum.go",
        "main.go",
        "manifest.go",
    ],
    importpath = "dominion/projects/game/windows_agent/release",
    visibility = ["//visibility:private"],
    deps = [
        "//pkg/s3",
        "@com_github_minio_minio_go_v7//:minio-go",
        "@com_github_spf13_pflag//:pflag",
    ],
)

go_binary(
    name = "publish_s3",
    embed = [":release_lib"],
    visibility = ["//visibility:public"],
)

go_unittest(
    name = "release_test",
    srcs = [
        "checksum_test.go",
        "manifest_test.go",
        "publish_test.go",
    ],
    embed = [":release_lib"],
    deps = ["@com_github_minio_minio_go_v7//:minio-go"],
)
